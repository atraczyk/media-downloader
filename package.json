{
  "name": "mp3-dl",
  "version": "2.0.0",
  "description": "Download audio and video from YouTube",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:mac": "npm run build && electron-builder --mac dmg",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "cli": "tsx src/cli/index.ts",
    "update-ytdlp": "node scripts/update-ytdlp.mjs"
  },
  "build": {
    "appId": "com.mp3dl.app",
    "productName": "Media Downloader",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      { "from": "resources", "to": ".", "filter": ["yt-dlp*"] }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "commander": "^12.1.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
