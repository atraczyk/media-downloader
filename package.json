{
  "name": "m-dl",
  "version": "2.0.0",
  "description": "Download audio and video from YouTube and more",
  "main": "out/main/index.js",
  "bin": {
    "m-dl": "./out/cli/cli/index.js"
  },
  "files": [
    "out/cli"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "npm run test:unit",
    "test:unit": "tsx --test \"src/**/*.test.ts\"",
    "bddgen": "bddgen",
    "test:bdd": "npm run bddgen && playwright test",
    "test:bdd:headed": "npm run bddgen && playwright test --headed",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:mac": "npm run build && electron-builder --mac dmg",
    "package:linux": "npm run build && electron-builder --linux AppImage",
    "build:cli": "tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run build:cli",
    "cli": "tsx src/cli/index.ts",
    "update-ytdlp": "node scripts/update-ytdlp.mjs"
  },
  "build": {
    "appId": "com.mediadl.app",
    "productName": "Media Downloader",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "yt-dlp*"
        ]
      }
    ],
    "win": {
      "artifactName": "media-downloader-setup-${version}.${ext}",
      "target": "nsis"
    },
    "mac": {
      "artifactName": "media-downloader-${version}.${ext}",
      "target": "dmg"
    },
    "linux": {
      "artifactName": "media-downloader-${version}.${ext}",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "commander": "^12.1.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "playwright-bdd": "^8.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "overrides": {
    "uuid": "^13.0.0"
  }
}
